#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="${HOME}/c9"
WORKSPACE_DIR="${BASE_DIR}/workspace"
COMPOSE_FILE="${BASE_DIR}/compose.yml"
CFG_FILE="${HOME}/.c9.env"

DEFAULT_PORT="8080"
DEFAULT_USER="admin"
DEFAULT_PASS="change-me"
DEFAULT_CONTAINER="cloud9"

ACTION="${1:-start}"

need_root() {
 if [ "$EUID" -ne 0 ]; then
  echo "Run with sudo"
  exit 1
 fi
}

install_docker() {
 if command -v docker >/dev/null 2>&1; then
  return
 fi

 curl -fsSL https://get.docker.com | sh

 systemctl enable docker
 systemctl start docker
}

load_cfg() {
 if [ ! -f "$CFG_FILE" ]; then
  cat > "$CFG_FILE" <<EOF
PORT=${DEFAULT_PORT}
C9_USER=${DEFAULT_USER}
C9_PASS=${DEFAULT_PASS}
CONTAINER_NAME=${DEFAULT_CONTAINER}
EOF
 fi

 set -a
 . "$CFG_FILE"
 set +a
}

write_compose() {
 mkdir -p "$WORKSPACE_DIR"

 cat > "$COMPOSE_FILE" <<EOF
services:
 cloud9:
  image: linuxserver/cloud9
  container_name: ${CONTAINER_NAME}
  environment:
   - USERNAME=${C9_USER}
   - PASSWORD=${C9_PASS}
  volumes:
   - ${WORKSPACE_DIR}:/code
  ports:
   - "${PORT}:8000"
  restart: unless-stopped
EOF
}

start_cloud9() {
 write_compose
 docker compose -f "$COMPOSE_FILE" up -d
}

stop_cloud9() {
 docker compose -f "$COMPOSE_FILE" down
}

need_root
load_cfg
install_docker

case "$ACTION" in
 start)
  start_cloud9
 ;;
 stop)
  stop_cloud9
 ;;
 restart)
  stop_cloud9
  start_cloud9
 ;;
 status)
  docker ps
 ;;
 *)
  echo "Usage: c9 {start|stop|restart|status}"
 ;;
esac
